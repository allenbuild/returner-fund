{
  "name": "yc-network-intelligence",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test && npm run build",
    "debug:evidence": "node scripts/debug-evidence-report.mjs",
    "debug:scoring": "node scripts/debug-scoring-report.mjs",
    "debug:coverage": "node scripts/debug-coverage-report.mjs",
    "debug:workers": "node scripts/debug-workers-report.mjs",
    "debug:duplicates": "node scripts/debug-duplicates-report.mjs",
    "debug:attribution": "node scripts/audit-evidence-attribution.mjs --write-doc",
    "debug:quality": "node scripts/run-quality-audit.mjs",
    "debug:quality:strict": "node scripts/run-quality-audit.mjs --strict",
    "debug:anomalies": "node scripts/run-anomaly-report.mjs",
    "thumbnails:backfill": "node scripts/backfill-evidence-thumbnails.mjs",
    "x:validate": "node scripts/backfill-evidence-thumbnails.mjs --platform=x --validate-x",
    "x:thumbnails": "node scripts/backfill-evidence-thumbnails.mjs --platform=x --validate-x --missing-only",
    "x:thumbnails:batch": "node scripts/backfill-evidence-thumbnails.mjs --platform=x --validate-x --missing-only --max-rows=100",
    "ingest:public": "node scripts/run-public-ingest.mjs",
    "ingest:s2026": "node scripts/fetch-public-traction.mjs --social=company",
    "ingest:resume": "node scripts/fetch-public-traction.mjs --social=company",
    "ingest:company": "node scripts/fetch-public-traction.mjs --social=all",
    "ingest:platform": "node scripts/fetch-public-traction.mjs --social=all",
    "ingest:logged-social": "node scripts/fetch-logged-in-social-traction.mjs",
    "instagram:doctor": "node scripts/instagram-doctor.mjs",
    "instagram:discover": "node scripts/discover-instagram-overrides.mjs",
    "scoring:experiments": "node scripts/run-scoring-experiments.mjs",
    "scoring:compare": "node scripts/run-scoring-experiments.mjs",
    "discovery:plan": "node scripts/plan-discovery-tasks.mjs",
    "longrun:checkpoint": "node scripts/long-run-checkpoint.mjs",
    "longrun:run": "node scripts/run-long-cycle.mjs",
    "longrun:run:6h": "node scripts/run-long-cycle.mjs --minutes=360 --checkpoint-minutes=30 --max-companies=197 --workers=8 --delay-ms=1200",
    "longrun:smoke": "node scripts/run-long-cycle.mjs --once --skip-build --skip-tests --skip-broad-ingest --max-companies=3 --workers=2 --delay-ms=250",
    "longrun:start": "node scripts/start-long-cycle.mjs",
    "longrun:status": "node scripts/long-run-status.mjs",
    "longrun:report": "node scripts/generate-long-run-report.mjs",
    "longrun:final-verify": "node scripts/run-final-verification.mjs",
    "attribution:loop": "node scripts/run-attribution-feedback-loop.mjs",
    "attribution:loop:5h": "node scripts/run-attribution-feedback-loop.mjs --minutes=300 --checkpoint-minutes=30"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.87.1",
    "cheerio": "^1.1.2",
    "cytoscape": "^3.34.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.561.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-cytoscapejs": "^2.0.0",
    "react-dom": "^19.2.7",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cytoscape": "^3.21.10",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
